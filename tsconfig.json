{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "nodenext",
    "target": "esnext",
    "types": [],

    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@config/*": ["./src/config/*"],
      "@postgres/*": [
        "./src/interfaces/postgres/*",
        "./src/shared/services/postgres/*"
      ],
      "@socket-io/*": [
        "./src/interfaces/socket-io/*",
        "./src/shared/services/socket-io/*"
      ],
      "@uuid/*": ["./src/interfaces/uuid/*"],
      "@routes/*": ["./src/routes/*"],
      "@constants/*": ["./src/constants/*"]
    },

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "references": [{ "path": "../../packages/core" }],
  "include": ["src"]
}
